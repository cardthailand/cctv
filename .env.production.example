# Production — copy to .env on server
NODE_ENV=production

CAMERA_IP=192.168.2.27
CAMERA_USER=admin
CAMERA_PASSWORD=your_camera_password
CAMERA_PORT=554
CHANNELS=1,2,3,4

HTTP_PORT=3000
WS_PORT_BASE=9000
USE_DIRECT_WS_PORT=false
RECORD_DIR=/home/cctv/domains/cctvcard.in.th/recordings
SEGMENT_SECONDS=3600
RETENTION_DAYS=30
CLEANUP_INTERVAL_HOURS=6

APP_URL=https://cctv.card.in.th
SESSION_SECRET=change_to_random_64_chars
WS_TOKEN_SECRET=change_to_random_64_chars
WS_TOKEN_EXPIRY_SEC=300

# DB on same server — use localhost
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=cctv_db
DB_USER=cctv_db
DB_PASSWORD=your_db_password
DB_SSL=false

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_on_first_run
ADMIN_EMAIL=admin@cctvcard.in.th

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://cctv.card.in.th/api/auth/google/callback

OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=your_ollama_api_key
OLLAMA_MODEL=glm-5.1:cloud
