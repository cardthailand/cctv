# Camera / NVR
CAMERA_IP=192.168.2.27
CAMERA_USER=admin
CAMERA_PASSWORD=your_camera_password
CAMERA_PORT=554
CHANNELS=1,2,3,4

# Server
HTTP_PORT=3000
WS_PORT_BASE=9000
RECORD_DIR=./recordings
SEGMENT_SECONDS=3600
RETENTION_DAYS=30
CLEANUP_INTERVAL_HOURS=6
SESSION_SECRET=change_me_to_random_64_chars
APP_URL=http://localhost:3000

# PostgreSQL
DB_HOST=ctb2.upz.in.th
DB_PORT=5432
DB_NAME=cctv_db
DB_USER=cctv_db
DB_PASSWORD=your_db_password
DB_SSL=true

# Auth - seed admin (first migration)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_on_first_run
ADMIN_EMAIL=admin@example.com

# Google OAuth (optional — leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Ollama AI Chat
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=your_ollama_api_key
OLLAMA_MODEL=glm-5.1:cloud

# WebSocket stream token
WS_TOKEN_SECRET=change_me_to_random_64_chars
WS_TOKEN_EXPIRY_SEC=300
